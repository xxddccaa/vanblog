{
  "name": "root",
  "version": "1.3.4",
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "pnpm": "^10.33.0"
  },
  "pnpm": {
    "overrides": {
      "baseline-browser-mapping": "^2.10.18",
      "browserslist": "^4.28.2",
      "caniuse-lite": "^1.0.30001787",
      "giget": "^1.2.3"
    }
  },
  "scripts": {
    "clean": "rm -rf node_modules && rm -rf packages/*/node_modules && rm -rf packages/*/dist && rm -rf packages/admin/src/.umi && rm -rf packages/admin/src/.umi-production",
    "build": "pnpm --filter @vanblog/server --filter @vanblog/theme-default --filter @vanblog/admin --parallel build",
    "build:admin": "pnpm --filter @vanblog/admin build",
    "build:server": "pnpm --filter @vanblog/server build",
    "build:test": "act -j test --secret-file=.env",
    "build:website": "pnpm --filter @vanblog/theme-default build",
    "dev": "pnpm --filter @vanblog/server --filter @vanblog/admin --parallel dev",
    "dev:server": "pnpm --filter @vanblog/server dev:noweb ",
    "dev:website": "pnpm --filter @vanblog/theme-default dev",
    "dev:admin": "pnpm --filter @vanblog/admin dev",
    "host:dev:up": "bash scripts/host-dev-up.sh",
    "host:dev:down": "bash scripts/host-dev-down.sh",
    "host:dev:status": "bash scripts/host-dev-status.sh",
    "test:current-stack": "pnpm test:current-stack:api && pnpm test:current-stack:admin",
    "test:current-stack:api": "node --test tests/current-stack.api.test.mjs",
    "test:current-stack:admin": "pnpm --filter @vanblog/admin test:current-stack",
    "test:deploy": "node --test tests/deployment-config.test.mjs",
    "test:blog-flow": "pnpm build:website && pnpm build:admin && node --test tests/deployment-config.test.mjs && node --test tests/blog-compose.e2e.test.mjs",
    "test:full": "pnpm --filter @vanblog/server test && pnpm --filter @vanblog/theme-default exec vitest run && pnpm --filter @vanblog/admin tsc && pnpm build:website && pnpm build:admin && pnpm test:deploy && node --test tests/blog-compose.e2e.test.mjs",
    "docs:build": "pnpm run -r docs:build",
    "docs:dev": "pnpm run -r docs:dev",
    "kill": "sudo bash scripts/kill-all.sh",
    "release:local": "act -j local-build --secret-file=.env",
    "release": "standard-version",
    "release-note": "node scripts/releaseNote.js",
    "release-doc": "node scripts/releaseDoc.js",
    "release-major": "standard-version --release-as major",
    "release-minor": "standard-version --release-as minor",
    "release-patch": "standard-version --release-as patch",
    "sync-aliyun": "bash scripts/sync-aliyuncs.sh",
    "webhook": "node scripts/webhook.js",
    "release:images": "bash scripts/release-images.sh",
    "release:images:push": "bash scripts/release-images.sh --push",
    "release:images:help": "bash scripts/release-images.sh --help"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nan": "^2.18.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@umijs/fabric": "^4.0.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "standard-version": "^9.5.0"
  }
}
