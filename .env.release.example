# Production deployment example for docker-compose.image.yml
# Copy this file to .env on the server and adjust the values before deployment.

TZ=Asia/Shanghai
EMAIL=admin@example.com

# Published image source
VANBLOG_DOCKER_REPO=kevinchina/deeplearning
VANBLOG_RELEASE_SUFFIX=v1.0.0-replace-with-gitsha8

# Public ports exposed by caddy only
VANBLOG_HTTP_PORT=80
VANBLOG_HTTPS_PORT=443

# Persistent data directories
VANBLOG_LOG_DIR=./log
VANBLOG_CADDY_CONFIG_DIR=./caddy/config
VANBLOG_CADDY_DATA_DIR=./caddy/data
VANBLOG_STATIC_DIR=./data/static
VANBLOG_MONGO_DIR=./data/mongo
VANBLOG_ALIYUNPAN_CONFIG_DIR=./aliyunpan/config

# Internal service configuration
VAN_BLOG_DATABASE_URL=mongodb://mongo:27017/vanBlog?authSource=admin
VAN_BLOG_WALINE_DB=waline
VAN_BLOG_ALLOW_DOMAINS=pic.mereith.com

# Waline / comment service secrets
WALINE_MONGO_HOST=mongo
WALINE_MONGO_PORT=27017
WALINE_JWT_TOKEN=please-change-this-to-a-long-random-secret

# Optional feature switches
INSTALL_ALIYUNPAN=false
