# Production deployment example for docker-compose.image.yml
# Copy this file to .env on the server and adjust the values before deployment.

TZ=Asia/Shanghai
EMAIL=admin@example.com

# Published image source
# Keep using kevinchina/deeplearning as the long-term retained backup repo.
VANBLOG_DOCKER_REPO=kevinchina/deeplearning
VANBLOG_RELEASE_SUFFIX=v1.4.1-replace-with-gitsha8

# Public ports exposed by caddy only
# Default mode exposes HTTP only. If you want built-in HTTPS management,
# add `-f docker-compose.https.yml` when starting the stack.
VANBLOG_HTTP_PORT=80
VANBLOG_HTTPS_PORT=443

# Persistent data directories
VANBLOG_LOG_DIR=./log
VANBLOG_CADDY_CONFIG_DIR=./caddy/config
VANBLOG_CADDY_DATA_DIR=./caddy/data
VANBLOG_STATIC_DIR=./data/static
VANBLOG_POSTGRES_DIR=./data/postgres
VANBLOG_REDIS_DIR=./data/redis
VANBLOG_ALIYUNPAN_CONFIG_DIR=./aliyunpan/config

# Internal service configuration
POSTGRES_DB=vanblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
VAN_BLOG_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/vanblog
VAN_BLOG_REDIS_URL=redis://redis:6379
VAN_BLOG_WALINE_DB=waline
VAN_BLOG_WALINE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/waline
VAN_BLOG_ALLOW_DOMAINS=pic.mereith.com
VAN_BLOG_CADDY_MANAGE_HTTPS=false
# Optional override. If left empty, VanBlog will generate a shared Waline JWT
# on first startup and persist it into VANBLOG_LOG_DIR/waline.jwt for reuse.
WALINE_JWT_TOKEN=

# Optional external Waline controller override
# VANBLOG_WALINE_CONTROL_URL=http://your-waline-host:8361

# Optional dedicated ISR shared secret for website revalidate requests.
# If left empty, the runtime falls back to WALINE_JWT_TOKEN in production.
# VANBLOG_ISR_TOKEN=replace-with-a-long-random-string

# Optional Cloudflare cache purge integration
# Leave both empty to disable tag/url purge after article and artifact updates.
# VAN_BLOG_CLOUDFLARE_API_TOKEN=replace-with-cloudflare-api-token
# VAN_BLOG_CLOUDFLARE_ZONE_ID=replace-with-cloudflare-zone-id

# Optional FastGPT internal endpoint for the admin AI workspace.
# Keep this on a private network path. If you use the bundled extension,
# the default value http://fastgpt-app:3000 works with
# `docker-compose.ai-qa.yml` + `docker-compose.fastgpt.yml`.
# VAN_BLOG_FASTGPT_INTERNAL_URL=http://fastgpt-app:3000
# If you want VanBlog admin to sync bundled FastGPT models automatically,
# set FASTGPT_ROOT_PASSWORD to the actual FastGPT root account password.
# FASTGPT_ROOT_PASSWORD=replace-with-fastgpt-root-password
# Optional bundled FastGPT bootstrap tuning. Only used together with
# `docker-compose.fastgpt.yml` when an old FastGPT data volume is missing
# the free `team_subscriptions` record required for Dataset/App creation.
# FASTGPT_FREE_PLAN_POINTS=100
# FASTGPT_FREE_PLAN_DURATION_DAYS=30

# Optional feature switches
INSTALL_ALIYUNPAN=false
