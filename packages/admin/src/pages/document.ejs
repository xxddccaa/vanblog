<!doctype html>
<html lang="cn">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#1772B4" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0"
    />
    <title>VanBlog Admin</title>
    <link id="vanblog-admin-favicon" rel="icon" href="/admin/logo.svg" type="image/x-icon" />
    <link
      id="vanblog-admin-favicon-shortcut"
      rel="shortcut icon"
      href="/admin/logo.svg"
      type="image/x-icon"
    />
    <script>
      (function () {
        var STORAGE_KEY = 'vanblog.admin.theme.config';
        var LEGACY_THEME = {
          lightPrimaryColor: '#1772b4',
          darkPrimaryColor: '#60a5fa',
          lightBackgroundColor: '#f4f8fb',
          darkBackgroundColor: '#111827',
        };
        var DEFAULT_THEME = {
          lightPrimaryColor: '#1772b4',
          darkPrimaryColor: '#8d9bb0',
          lightBackgroundColor: '#f4f8fb',
          darkBackgroundColor: '#111315',
        };
        var COLOR_PATTERN = /^#[0-9a-f]{6}$/i;

        function clamp(value, min, max) {
          return Math.min(max, Math.max(min, value));
        }

        function normalizeColor(value, fallback) {
          var normalized = String(value || '')
            .trim()
            .toLowerCase();
          return COLOR_PATTERN.test(normalized) ? normalized : fallback;
        }

        function normalizeTheme(value) {
          var normalized = {
            lightPrimaryColor: normalizeColor(
              value && value.lightPrimaryColor,
              DEFAULT_THEME.lightPrimaryColor,
            ),
            darkPrimaryColor: normalizeColor(
              value && value.darkPrimaryColor,
              DEFAULT_THEME.darkPrimaryColor,
            ),
            lightBackgroundColor: normalizeColor(
              value && value.lightBackgroundColor,
              DEFAULT_THEME.lightBackgroundColor,
            ),
            darkBackgroundColor: normalizeColor(
              value && value.darkBackgroundColor,
              DEFAULT_THEME.darkBackgroundColor,
            ),
          };
          var shouldUpgradeLegacyTheme =
            normalized.lightPrimaryColor === LEGACY_THEME.lightPrimaryColor &&
            normalized.darkPrimaryColor === LEGACY_THEME.darkPrimaryColor &&
            normalized.lightBackgroundColor === LEGACY_THEME.lightBackgroundColor &&
            normalized.darkBackgroundColor === LEGACY_THEME.darkBackgroundColor;
          return shouldUpgradeLegacyTheme ? DEFAULT_THEME : normalized;
        }

        function readTheme() {
          try {
            var raw = window.localStorage.getItem(STORAGE_KEY);
            if (!raw) {
              return DEFAULT_THEME;
            }
            return normalizeTheme(JSON.parse(raw));
          } catch (error) {
            return DEFAULT_THEME;
          }
        }

        function hexToRgb(value) {
          var normalized = normalizeColor(value, '');
          if (!normalized) {
            return null;
          }
          var numeric = parseInt(normalized.slice(1), 16);
          return {
            r: (numeric >> 16) & 255,
            g: (numeric >> 8) & 255,
            b: numeric & 255,
          };
        }

        function rgbToHex(rgb) {
          return (
            '#' +
            [rgb.r, rgb.g, rgb.b]
              .map(function (item) {
                return clamp(Math.round(item), 0, 255).toString(16).padStart(2, '0');
              })
              .join('')
          );
        }

        function mixHexColors(base, overlay, weight) {
          var baseRgb = hexToRgb(base);
          var overlayRgb = hexToRgb(overlay);
          if (!baseRgb || !overlayRgb) {
            return normalizeColor(base, overlay);
          }
          var ratio = clamp(weight, 0, 1);
          return rgbToHex({
            r: baseRgb.r + (overlayRgb.r - baseRgb.r) * ratio,
            g: baseRgb.g + (overlayRgb.g - baseRgb.g) * ratio,
            b: baseRgb.b + (overlayRgb.b - baseRgb.b) * ratio,
          });
        }

        function toRgba(value, alpha) {
          var rgb = hexToRgb(value);
          if (!rgb) {
            return value;
          }
          return 'rgba(' + rgb.r + ', ' + rgb.g + ', ' + rgb.b + ', ' + alpha + ')';
        }

        function resolveThemeMode() {
          try {
            if (window.localStorage.theme === 'dark') {
              return 'dark';
            }
            if (window.localStorage.theme === 'auto') {
              var hour = new Date().getHours();
              var night = hour > 18 || hour < 8;
              if (night || window.matchMedia('(prefers-color-scheme: dark)').matches) {
                return 'dark';
              }
            }
          } catch (error) {}
          return 'light';
        }

        var themeMode = resolveThemeMode();
        var themeConfig = readTheme();
        var primaryColor =
          themeMode === 'dark' ? themeConfig.darkPrimaryColor : themeConfig.lightPrimaryColor;
        var backgroundColor =
          themeMode === 'dark' ? themeConfig.darkBackgroundColor : themeConfig.lightBackgroundColor;
        var surfaceBg =
          themeMode === 'dark' ? backgroundColor : mixHexColors(backgroundColor, '#ffffff', 0.72);
        var surfaceBgSubtle =
          themeMode === 'dark'
            ? backgroundColor
            : mixHexColors(backgroundColor, primaryColor, 0.05);
        var surfaceBgElevated = themeMode === 'dark' ? backgroundColor : '#ffffff';
        var siderBg =
          themeMode === 'dark' ? backgroundColor : mixHexColors(backgroundColor, '#ffffff', 0.82);
        var tableHeaderBg =
          themeMode === 'dark'
            ? backgroundColor
            : mixHexColors(backgroundColor, primaryColor, 0.08);
        var appBackground =
          themeMode === 'dark' ? backgroundColor : mixHexColors(backgroundColor, '#ffffff', 0.35);
        var documentBase =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.025)
            : mixHexColors(backgroundColor, '#ffffff', 0.92);
        var documentTreeBg =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.04)
            : mixHexColors(backgroundColor, '#ffffff', 0.9);
        var documentEditorBg =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.03) : '#ffffff';
        var documentPreviewBgSoft =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.055)
            : '#eef6ff';
        var documentPreviewBg =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.035) : '#f8fafc';
        var documentToolbarBg =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.045)
            : mixHexColors(backgroundColor, '#ffffff', 0.96);
        var documentScrollTrack = themeMode === 'dark' ? toRgba('#ffffff', 0.04) : '#f1f5f9';
        var documentScrollThumb = themeMode === 'dark' ? toRgba('#ffffff', 0.14) : '#c1c9d4';
        var documentCodeBtnText = themeMode === 'dark' ? '#bcc4cd' : '#6f7177';
        var documentCodeBtnHover =
          themeMode === 'dark' ? toRgba('#ffffff', 0.06) : 'rgb(229 231 235)';
        var documentCodeFade =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.03) : '#f6f8fa';
        var editorCanvasBg = themeMode === 'dark' ? backgroundColor : '#ffffff';
        var editorBg =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.025) : '#ffffff';
        var editorPanelBg =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.04)
            : mixHexColors(backgroundColor, '#ffffff', 0.98);
        var editorPanelBgAlt =
          themeMode === 'dark'
            ? mixHexColors(backgroundColor, '#ffffff', 0.055)
            : mixHexColors(backgroundColor, primaryColor, 0.05);
        var editorPreviewBg =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.035) : '#f8fafc';
        var editorBorder =
          themeMode === 'dark' ? toRgba('#ffffff', 0.07) : 'rgba(15, 23, 42, 0.08)';
        var editorBorderStrong =
          themeMode === 'dark' ? toRgba('#ffffff', 0.1) : toRgba(primaryColor, 0.18);
        var editorText = themeMode === 'dark' ? '#eceff4' : '#0f172a';
        var editorMuted = themeMode === 'dark' ? '#bcc4cd' : '#52637a';
        var editorSubtle = themeMode === 'dark' ? '#9098a2' : '#7b8794';
        var editorAccent = primaryColor;
        var editorAccentStrong =
          themeMode === 'dark'
            ? mixHexColors(primaryColor, '#ffffff', 0.08)
            : mixHexColors(primaryColor, '#0f172a', 0.08);
        var editorHover =
          themeMode === 'dark' ? toRgba('#ffffff', 0.05) : toRgba(primaryColor, 0.08);
        var editorActive =
          themeMode === 'dark' ? toRgba('#ffffff', 0.08) : toRgba(primaryColor, 0.14);
        var editorSelection = toRgba(primaryColor, themeMode === 'dark' ? 0.16 : 0.14);
        var editorShadow =
          themeMode === 'dark'
            ? '0 14px 36px rgba(0, 0, 0, 0.18)'
            : '0 18px 42px ' + toRgba(primaryColor, 0.12);
        var editorMermaidBg =
          themeMode === 'dark' ? mixHexColors(backgroundColor, '#ffffff', 0.035) : '#eef7ff';
        var editorMermaidBorder =
          themeMode === 'dark' ? toRgba('#ffffff', 0.08) : '#d6e7f7';
        var editorMermaidText = themeMode === 'dark' ? '#d6dde6' : '#0f4f8a';
        var authBackground =
          themeMode === 'dark'
            ? 'linear-gradient(180deg, ' +
              mixHexColors(backgroundColor, '#191c20', 0.08) +
              ' 0%, ' +
              backgroundColor +
              ' 100%)'
            : 'radial-gradient(circle at top, ' +
              toRgba(primaryColor, 0.14) +
              ', transparent 40%), radial-gradient(circle at bottom right, ' +
              toRgba(primaryColor, 0.08) +
              ', transparent 34%), linear-gradient(180deg, ' +
              mixHexColors(backgroundColor, '#ffffff', 0.52) +
              ' 0%, ' +
              backgroundColor +
              ' 54%, ' +
              mixHexColors(backgroundColor, '#ffffff', 0.7) +
              ' 100%)';

        document.documentElement.dataset.theme = themeMode;
        document.documentElement.style.colorScheme = themeMode;
        document.documentElement.classList.toggle('dark', themeMode === 'dark');
        document.documentElement.style.setProperty('--admin-primary', primaryColor);
        document.documentElement.style.setProperty(
          '--admin-primary-soft-bg',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.1),
        );
        document.documentElement.style.setProperty(
          '--admin-primary-soft-border',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.2),
        );
        document.documentElement.style.setProperty('--admin-primary-text', primaryColor);
        document.documentElement.style.setProperty('--admin-primary-link', primaryColor);
        document.documentElement.style.setProperty('--admin-auth-background', authBackground);
        document.documentElement.style.setProperty(
          '--admin-auth-panel-bg',
          themeMode === 'dark' ? backgroundColor : 'rgba(255, 255, 255, 0.88)',
        );
        document.documentElement.style.setProperty(
          '--admin-auth-panel-border',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.16),
        );
        document.documentElement.style.setProperty(
          '--admin-auth-panel-shadow',
          themeMode === 'dark'
            ? 'none'
            : '0 24px 72px ' + toRgba(primaryColor, 0.16) + ', 0 0 0 1px rgba(255, 255, 255, 0.55)',
        );
        document.documentElement.style.setProperty(
          '--admin-auth-text',
          themeMode === 'dark' ? '#eceff4' : '#0f172a',
        );
        document.documentElement.style.setProperty(
          '--admin-auth-text-secondary',
          themeMode === 'dark' ? '#a5adb7' : '#52637a',
        );
        document.documentElement.style.setProperty(
          '--admin-auth-input-bg',
          themeMode === 'dark' ? backgroundColor : 'rgba(255, 255, 255, 0.92)',
        );
        document.documentElement.style.setProperty(
          '--admin-auth-input-border',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.16),
        );
        document.documentElement.style.setProperty('--admin-auth-link', primaryColor);
        document.documentElement.style.setProperty('--admin-loading-color', primaryColor);
        document.documentElement.style.setProperty('--admin-app-background', appBackground);
        document.documentElement.style.setProperty('--admin-surface-bg', surfaceBg);
        document.documentElement.style.setProperty('--admin-surface-bg-subtle', surfaceBgSubtle);
        document.documentElement.style.setProperty(
          '--admin-surface-bg-elevated',
          surfaceBgElevated,
        );
        document.documentElement.style.setProperty(
          '--admin-surface-border',
          themeMode === 'dark' ? 'transparent' : 'rgba(5, 5, 5, 0.06)',
        );
        document.documentElement.style.setProperty('--admin-document-tree-bg', documentTreeBg);
        document.documentElement.style.setProperty('--admin-document-editor-bg', documentEditorBg);
        document.documentElement.style.setProperty(
          '--admin-document-preview-bg-soft',
          documentPreviewBgSoft,
        );
        document.documentElement.style.setProperty(
          '--admin-document-preview-bg',
          documentPreviewBg,
        );
        document.documentElement.style.setProperty(
          '--admin-document-toolbar-bg',
          documentToolbarBg,
        );
        document.documentElement.style.setProperty(
          '--admin-document-scroll-track',
          documentScrollTrack,
        );
        document.documentElement.style.setProperty(
          '--admin-document-scroll-thumb',
          documentScrollThumb,
        );
        document.documentElement.style.setProperty(
          '--admin-document-code-btn-text',
          documentCodeBtnText,
        );
        document.documentElement.style.setProperty(
          '--admin-document-code-btn-hover',
          documentCodeBtnHover,
        );
        document.documentElement.style.setProperty('--admin-document-code-fade', documentCodeFade);
        document.documentElement.style.setProperty(
          '--admin-document-divider',
          themeMode === 'dark' ? toRgba('#ffffff', 0.06) : 'rgba(5, 5, 5, 0.06)',
        );
        document.documentElement.style.setProperty('--admin-editor-canvas-bg', editorCanvasBg);
        document.documentElement.style.setProperty('--admin-editor-bg', editorBg);
        document.documentElement.style.setProperty('--admin-editor-panel-bg', editorPanelBg);
        document.documentElement.style.setProperty('--admin-editor-panel-bg-alt', editorPanelBgAlt);
        document.documentElement.style.setProperty('--admin-editor-preview-bg', editorPreviewBg);
        document.documentElement.style.setProperty('--admin-editor-border', editorBorder);
        document.documentElement.style.setProperty(
          '--admin-editor-border-strong',
          editorBorderStrong,
        );
        document.documentElement.style.setProperty('--admin-editor-text', editorText);
        document.documentElement.style.setProperty('--admin-editor-muted', editorMuted);
        document.documentElement.style.setProperty('--admin-editor-subtle', editorSubtle);
        document.documentElement.style.setProperty('--admin-editor-accent', editorAccent);
        document.documentElement.style.setProperty(
          '--admin-editor-accent-strong',
          editorAccentStrong,
        );
        document.documentElement.style.setProperty('--admin-editor-hover', editorHover);
        document.documentElement.style.setProperty('--admin-editor-active', editorActive);
        document.documentElement.style.setProperty('--admin-editor-selection', editorSelection);
        document.documentElement.style.setProperty('--admin-editor-shadow', editorShadow);
        document.documentElement.style.setProperty('--admin-editor-mermaid-bg', editorMermaidBg);
        document.documentElement.style.setProperty(
          '--admin-editor-mermaid-border',
          editorMermaidBorder,
        );
        document.documentElement.style.setProperty(
          '--admin-editor-mermaid-text',
          editorMermaidText,
        );
        document.documentElement.style.setProperty('--admin-modal-bg', surfaceBg);
        document.documentElement.style.setProperty('--admin-modal-bg-subtle', surfaceBgSubtle);
        document.documentElement.style.setProperty(
          '--admin-modal-border',
          themeMode === 'dark' ? 'transparent' : 'rgba(5, 5, 5, 0.08)',
        );
        document.documentElement.style.setProperty(
          '--admin-modal-text',
          themeMode === 'dark' ? '#eceff4' : '#0f172a',
        );
        document.documentElement.style.setProperty(
          '--admin-modal-text-secondary',
          themeMode === 'dark' ? '#a5adb7' : '#52637a',
        );
        document.documentElement.style.setProperty(
          '--admin-modal-warning-bg',
          themeMode === 'dark' ? backgroundColor : 'rgba(245, 158, 11, 0.14)',
        );
        document.documentElement.style.setProperty(
          '--admin-modal-warning-text',
          themeMode === 'dark' ? '#eceff4' : '#b45309',
        );
        document.documentElement.style.setProperty(
          '--admin-overlay-mask',
          themeMode === 'dark' ? 'rgba(0, 0, 0, 0.72)' : 'rgba(15, 23, 42, 0.18)',
        );
        document.documentElement.style.setProperty('--admin-sider-bg', siderBg);
        document.documentElement.style.setProperty(
          '--admin-sider-text',
          themeMode === 'dark' ? '#bcc4cd' : 'rgba(0, 0, 0, 0.65)',
        );
        document.documentElement.style.setProperty(
          '--admin-sider-secondary-text',
          themeMode === 'dark' ? '#98a1ab' : 'rgba(0, 0, 0, 0.45)',
        );
        document.documentElement.style.setProperty(
          '--admin-sider-strong-text',
          themeMode === 'dark' ? '#f2f4f7' : 'rgba(0, 0, 0, 0.88)',
        );
        document.documentElement.style.setProperty(
          '--admin-sider-hover-bg',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.08),
        );
        document.documentElement.style.setProperty(
          '--admin-sider-selected-bg',
          themeMode === 'dark' ? 'transparent' : toRgba(primaryColor, 0.12),
        );
        document.documentElement.style.setProperty('--admin-sider-selected-text', primaryColor);
        document.documentElement.style.setProperty(
          '--admin-sider-border',
          themeMode === 'dark' ? 'transparent' : 'rgba(5, 5, 5, 0.06)',
        );
        document.documentElement.style.setProperty('--admin-table-header-bg', tableHeaderBg);

        var themeColorMeta = document.querySelector('meta[name="theme-color"]');
        if (themeColorMeta) {
          themeColorMeta.setAttribute('content', primaryColor);
        }
      })();
    </script>
  </head>

  <body>
    <noscript>
      <div class="noscript-container">
        Hi there! Please
        <div class="noscript-enableJS">
          <a href="https://www.enablejavascript.io/en" target="_blank" rel="noopener noreferrer">
            <b>enable Javascript</b>
          </a>
        </div>
        in your browser to use Ant Design, Out-of-the-box mid-stage front/design solution!
      </div>
    </noscript>
    <div id="root">
      <style>
        html,
        body,
        #root {
          height: 100%;
          margin: 0;
          padding: 0;
        }

        html,
        body,
        #root {
          background: var(--admin-auth-background, var(--admin-app-background, #f4f8fb));
        }

        #root {
          background-repeat: no-repeat;
          background-size: 100% auto;
        }

        .noscript-container {
          display: flex;
          align-content: center;
          justify-content: center;
          margin-top: 90px;
          font-size: 20px;
          font-family: 'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode',
            Geneva, Verdana, sans-serif;
        }

        .noscript-enableJS {
          padding-right: 3px;
          padding-left: 3px;
        }

        .page-loading-warp {
          display: flex;
          align-items: center;
          justify-content: center;
          padding: 98px;
        }

        .ant-spin {
          position: absolute;
          display: none;
          -webkit-box-sizing: border-box;
          box-sizing: border-box;
          margin: 0;
          padding: 0;
          color: var(--admin-loading-color, #1772b4);
          font-size: 14px;
          font-variant: tabular-nums;
          line-height: 1.5;
          text-align: center;
          list-style: none;
          opacity: 0;
          -webkit-transition: -webkit-transform 0.3s cubic-bezier(0.78, 0.14, 0.15, 0.86);
          transition: -webkit-transform 0.3s cubic-bezier(0.78, 0.14, 0.15, 0.86);
          transition: transform 0.3s cubic-bezier(0.78, 0.14, 0.15, 0.86);
          transition:
            transform 0.3s cubic-bezier(0.78, 0.14, 0.15, 0.86),
            -webkit-transform 0.3s cubic-bezier(0.78, 0.14, 0.15, 0.86);
          -webkit-font-feature-settings: 'tnum';
          font-feature-settings: 'tnum';
        }

        .ant-spin-spinning {
          position: static;
          display: inline-block;
          opacity: 1;
        }

        .ant-spin-dot {
          position: relative;
          display: inline-block;
          width: 20px;
          height: 20px;
          font-size: 20px;
        }

        .ant-spin-dot-item {
          position: absolute;
          display: block;
          width: 9px;
          height: 9px;
          background-color: var(--admin-loading-color, #1772b4);
          border-radius: 100%;
          -webkit-transform: scale(0.75);
          -ms-transform: scale(0.75);
          transform: scale(0.75);
          -webkit-transform-origin: 50% 50%;
          -ms-transform-origin: 50% 50%;
          transform-origin: 50% 50%;
          opacity: 0.3;
          -webkit-animation: antspinmove 1s infinite linear alternate;
          animation: antSpinMove 1s infinite linear alternate;
        }

        .ant-spin-dot-item:nth-child(1) {
          top: 0;
          left: 0;
        }

        .ant-spin-dot-item:nth-child(2) {
          top: 0;
          right: 0;
          -webkit-animation-delay: 0.4s;
          animation-delay: 0.4s;
        }

        .ant-spin-dot-item:nth-child(3) {
          right: 0;
          bottom: 0;
          -webkit-animation-delay: 0.8s;
          animation-delay: 0.8s;
        }

        .ant-spin-dot-item:nth-child(4) {
          bottom: 0;
          left: 0;
          -webkit-animation-delay: 1.2s;
          animation-delay: 1.2s;
        }

        .ant-spin-dot-spin {
          -webkit-transform: rotate(45deg);
          -ms-transform: rotate(45deg);
          transform: rotate(45deg);
          -webkit-animation: antrotate 1.2s infinite linear;
          animation: antRotate 1.2s infinite linear;
        }

        .ant-spin-lg .ant-spin-dot {
          width: 32px;
          height: 32px;
          font-size: 32px;
        }

        .ant-spin-lg .ant-spin-dot i {
          width: 14px;
          height: 14px;
        }

        @media all and (-ms-high-contrast: none), (-ms-high-contrast: active) {
          .ant-spin-blur {
            background: #fff;
            opacity: 0.5;
          }
        }

        @-webkit-keyframes antSpinMove {
          to {
            opacity: 1;
          }
        }

        @keyframes antSpinMove {
          to {
            opacity: 1;
          }
        }

        @-webkit-keyframes antRotate {
          to {
            -webkit-transform: rotate(405deg);
            transform: rotate(405deg);
          }
        }

        @keyframes antRotate {
          to {
            -webkit-transform: rotate(405deg);
            transform: rotate(405deg);
          }
        }
      </style>
      <div
        style="
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
          height: 100%;
          min-height: 420px;
        "
      >
        <div class="page-loading-warp">
          <div class="ant-spin ant-spin-lg ant-spin-spinning">
            <span class="ant-spin-dot ant-spin-dot-spin"
              ><i class="ant-spin-dot-item"></i><i class="ant-spin-dot-item"></i
              ><i class="ant-spin-dot-item"></i><i class="ant-spin-dot-item"></i
            ></span>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
