{
  "name": "@vanblog/admin",
  "version": "5.2.0",
  "private": true,
  "description": "An out-of-box UI solution for enterprise applications",
  "scripts": {
    "analyze": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 ANALYZE=1 max build",
    "build": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 EEE=production max build && node ../../scripts/patch-admin-runtime-keys.mjs && node ../../scripts/build-mindmap-assets.mjs",
    "deploy": "npm run build && npm run gh-pages",
    "dev": "npm run start:dev",
    "gh-pages": "gh-pages -d dist",
    "lint": "npm run lint:js && npm run lint:style && npm run lint:prettier && npm run tsc",
    "lint-staged": "lint-staged",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx ",
    "lint:fix": "eslint --fix --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src && npm run lint:style",
    "lint:js": "eslint --cache --ext .js,.jsx,.ts,.tsx --format=pretty ./src",
    "lint:prettier": "prettier -c --write \"src/**/*\" --end-of-line auto",
    "lint:style": "stylelint --fix \"src/**/*.less\" --syntax less",
    "openapi": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 max openapi",
    "playwright": "playwright install && playwright test",
    "prepare": "echo 'pre'",
    "prettier": "prettier -c --write \"src/**/*\"",
    "serve": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 max preview",
    "start": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 MOCK=none UMI_ENV=dev PORT=3002 max dev",
    "start:dev": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 REACT_APP_ENV=dev MOCK=none UMI_ENV=dev max dev",
    "start:no-mock": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 MOCK=none UMI_ENV=dev max dev",
    "start:no-ui": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 UMI_UI=none UMI_ENV=dev max dev",
    "start:node17": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 MOCK=none UMI_ENV=dev PORT=3002 max dev",
    "start:pre": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 REACT_APP_ENV=pre UMI_ENV=dev max dev",
    "start:test": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 REACT_APP_ENV=test MOCK=none UMI_ENV=dev max dev",
    "test:current-stack": "node tests/current-stack.smoke.cjs",
    "test": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 max test",
    "test:component": "cross-env BROWSERSLIST_IGNORE_OLD_DATA=1 max test ./src/components",
    "test:e2e": "node ./tests/run-tests.js",
    "tsc": "tsc --noEmit"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 10"
  ],
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "@ant-design/plots": "^2.6.5",
    "@ant-design/pro-card": "^2.10.0",
    "@ant-design/pro-components": "^2.8.10",
    "@ant-design/pro-descriptions": "^2.6.10",
    "@ant-design/pro-form": "^2.32.0",
    "@ant-design/pro-layout": "^7.22.7",
    "@ant-design/pro-table": "^3.21.0",
    "@bytemd/plugin-breaks": "^1.22.0",
    "@bytemd/plugin-frontmatter": "^1.22.0",
    "@bytemd/plugin-gfm": "^1.22.0",
    "@bytemd/plugin-highlight-ssr": "^1.22.0",
    "@bytemd/plugin-math-ssr": "^1.22.0",
    "@bytemd/plugin-medium-zoom": "^1.22.0",
    "@bytemd/plugin-mermaid": "^1.22.0",
    "@bytemd/react": "^1.22.0",
    "@emoji-mart/data": "^1.1.2",
    "@emoji-mart/react": "^1.1.1",
    "@umijs/max": "^4.6.42",
    "ansi-to-html": "^0.7.2",
    "antd": "^5.29.3",
    "antd-img-crop": "^4.17.0",
    "btoa": "^1.2.1",
    "bytemd": "^1.22.0",
    "classnames": "^2.3.2",
    "copy-to-clipboard": "^3.3.3",
    "emoji-mart": "^5.5.2",
    "front-matter": "^4.0.2",
    "highlight.js": "^11.9.0",
    "js-sha256": "^0.9.0",
    "jszip": "^3.10.1",
    "katex": "^0.16.9",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "monaco-editor": "^0.34.1",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "omit.js": "^2.0.2",
    "pinyin-match": "^1.2.5",
    "rc-menu": "^9.12.2",
    "rc-resize-observer": "^1.4.0",
    "rc-util": "^5.38.1",
    "react": "^18.3.1",
    "react-contexify": "^5.0.0",
    "react-dev-inspector": "^1.9.0",
    "react-dom": "^18.3.1",
    "react-monaco-editor": "^0.50.1",
    "rehype-raw": "^6.1.1",
    "remark-directive": "^2.0.1",
    "unist-util-visit": "^4.1.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/express": "^4.17.21",
    "@types/history": "^4.7.11",
    "@types/jest": "^26.0.24",
    "@types/lodash": "^4.14.202",
    "@types/jszip": "^3.4.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@umijs/openapi": "^1.14.1",
    "cross-env": "^7.0.3",
    "eslint": "^7.32.0",
    "gh-pages": "^3.2.3",
    "mockjs": "^1.1.0",
    "stylelint": "^13.13.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24 <25"
  }
}
